# ──────────────────────────────────────────────────────────────
# LogMonitor Dashboard — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs
# ──────────────────────────────────────────────────────────────

# Django
SECRET_KEY=changeme-generate-with-python-secrets-token-hex-50
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL
# Format : postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://logmonitor:logmonitor@localhost:5432/logmonitor_db

# SQLite pour développement rapide (commenter DATABASE_URL ci-dessus)
# DATABASE_URL=sqlite:///db.sqlite3

# Email (optionnel)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
